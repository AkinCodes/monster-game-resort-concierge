# ============================================================
# Monster Game Resort Concierge — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Minimum required: at least one LLM provider key (OpenAI or Anthropic)
# ============================================================

# --- App ---
MRC_ENVIRONMENT=dev                    # dev | test | staging | prod
MRC_HOST=0.0.0.0
MRC_PORT=8000
MRC_LOG_LEVEL=info                     # debug | info | warning | error

# --- LLM Provider Keys (at least one required) ---
MRC_OPENAI_API_KEY=your-openai-key-here
MRC_ANTHROPIC_API_KEY=your-anthropic-key-here

# --- LLM Configuration ---
MRC_LLM_PROVIDER_PRIORITY=openai,anthropic,ollama
MRC_LLM_FALLBACK_ENABLED=true
MRC_OPENAI_MODEL=gpt-4o-mini
MRC_OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
MRC_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Ollama (local models, optional) ---
MRC_OLLAMA_ENABLED=false
MRC_OLLAMA_BASE_URL=http://localhost:11434
MRC_OLLAMA_MODEL=llama3

# --- Database (SQLite default; PostgreSQL for production) ---
MRC_DATABASE_URL=sqlite:///./monster_resort.db
# MRC_DATABASE_URL=postgresql://monster:monster_secret@localhost:5432/monster_resort

# --- Redis Caching (disabled by default; falls back to in-memory) ---
MRC_REDIS_ENABLED=false
MRC_REDIS_URL=redis://localhost:6379/0

# --- RAG ---
MRC_RAG_COLLECTION=monster_resort_knowledge
MRC_RAG_PERSIST_DIR=./.rag_store
MRC_RAG_MAX_RESULTS=5
MRC_RAG_INGESTION_TOKEN=your-ingestion-token-here

# --- Hallucination Detection ---
MRC_HALLUCINATION_HIGH_THRESHOLD=0.7
MRC_HALLUCINATION_MEDIUM_THRESHOLD=0.4

# --- Security ---
MRC_API_KEY=your-api-key-here
MRC_RATE_LIMIT_PER_MINUTE=60

# --- MLflow (optional) ---
MRC_MLFLOW_ENABLED=false
MRC_MLFLOW_TRACKING_URI=http://localhost:5000
MRC_MLFLOW_EXPERIMENT_NAME=monster-resort-concierge

# --- PDFs ---
MRC_PDF_OUTPUT_DIR=./generated_pdfs

# --- Optional Features ---
MRC_ENABLE_GRADIO=false
