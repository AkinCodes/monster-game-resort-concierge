# LLM Provider Keys (at least one required)
MRC_OPENAI_API_KEY=your-openai-key-here
MRC_ANTHROPIC_API_KEY=your-anthropic-key-here
MRC_OLLAMA_ENABLED=false

# LLM Configuration
MRC_LLM_PROVIDER_PRIORITY=openai,anthropic,ollama
MRC_LLM_FALLBACK_ENABLED=true
MRC_OPENAI_MODEL=gpt-4o

# API Security
MRC_API_KEY=your-api-key-here
MRC_JWT_SECRET=your-jwt-secret-here

# Hallucination Detection
MRC_HALLUCINATION_HIGH_THRESHOLD=0.7

# Database (SQLite default; use postgresql:// for Postgres)
MRC_DATABASE_URL=sqlite:///./monster_resort.db
# MRC_DATABASE_URL=postgresql://monster:monster_secret@localhost:5432/monster_resort

# Redis Caching (disabled by default)
MRC_REDIS_URL=redis://localhost:6379/0
MRC_REDIS_ENABLED=false

# Optional Features
MRC_ENABLE_GRADIO=false
MRC_MLFLOW_ENABLED=false
